# Supabase — used by both the worship app backend and Vocal Hero
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Vocal Hero Python pipeline (optional — only needed for YouTube import)
PIPELINE_URL=https://your-pipeline-server.com
PIPELINE_SECRET=your-pipeline-secret

# Roster → Google Calendar push-sync (instant duty invites, see
# migrations/2026-07-18_add_calendar_sync_events.sql and app/api/calendar-sync)
# Owned by a DEDICATED Google account (not a real member's personal account) so
# no one who receives duty invites also sees the full roster as the calendar owner.
GOOGLE_CLIENT_ID=your-oauth-client-id
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_REFRESH_TOKEN=your-long-lived-refresh-token
GOOGLE_CALENDAR_ID=your-dedicated-calendar-id@group.calendar.google.com
# Optional — protects the /api/calendar-reconcile GET (cron) path only
CRON_SECRET=a-random-secret-string
